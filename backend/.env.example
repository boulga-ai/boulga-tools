# ---- Supabase ----
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=

# ---- OpenRouter ----
OPENROUTER_API_KEY=sk-or-v1-...

# ---- Copyleaks ----
COPYLEAKS_EMAIL=
COPYLEAKS_API_KEY=

# ---- FedaPay (branche plus tard) ----
FEDAPAY_PUBLIC_KEY=
FEDAPAY_SECRET_KEY=
FEDAPAY_WEBHOOK_SECRET=

# ---- App ----
ENV=dev
PORT=8003
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
ADMIN_EMAIL=boulgacorporation@gmail.com

# ---- Matrice LLM (JSON, surchargeable sans redeploiement) ----
LLM_ROUTING_JSON=

# ---- Convertisseur de fichiers ----
# Chemin/nom du binaire LibreOffice headless. Par defaut "soffice" (doit etre sur le PATH).
# En local sans LibreOffice installe, la conversion Office <-> PDF echoue proprement
# (message clair) ; la conversion d'images et la fusion/separation de PDF restent operationnelles.
SOFFICE_BIN=soffice
